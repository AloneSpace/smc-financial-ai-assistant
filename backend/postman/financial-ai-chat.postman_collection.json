{
  "info": {
    "name": "Financial AI Chat Assistant API",
    "_postman_id": "f1a2c3d4-5e6f-4a7b-8c9d-0e1f2a3b4c5d",
    "description": "REST + SSE API for the Financial AI Chat Assistant.\n\nAll answers are grounded in PostgreSQL financial data via SQL tool calling.\n\n## Getting started\n1. Set the `baseUrl` collection variable (default `http://localhost:3000`).\n2. Run **Auth → Register** (or **Login**) — the test script stores the JWT in `accessToken` automatically.\n3. Run **Conversations → Create** — stores `conversationId` automatically.\n4. Run **Chat → Send message** (SSE stream).\n\nAll protected requests inherit Bearer auth from the collection using `{{accessToken}}`.\n\nInteractive API reference (Scalar): `{{baseUrl}}/reference`\nRaw OpenAPI document: `{{baseUrl}}/api/openapi.json`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "conversationId", "value": "", "type": "string" },
    { "key": "messageId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "  pm.test('accessToken returned', () => pm.expect(body.accessToken).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. Returns `{ accessToken, user }`. Email must be unique (409 on duplicate); password 8–200 chars."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "if (body.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', body.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Log in with email + password. Returns `{ accessToken, user }`. 401 on bad credentials."
          }
        },
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Returns the currently authenticated user `{ id, email, createdAt }`. Requires Bearer token."
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "Create conversation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "if (body.id) {",
                  "  pm.collectionVariables.set('conversationId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Apple revenue questions\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/conversations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "conversations"]
            },
            "description": "Create a conversation. `title` is optional (max 255 chars). Returns `{ id, title, createdAt, updatedAt }`."
          }
        },
        {
          "name": "List conversations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/conversations?limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "conversations"],
              "query": [
                { "key": "limit", "value": "20", "description": "1–50, default 20" },
                { "key": "offset", "value": "0", "description": "min 0, default 0" }
              ]
            },
            "description": "Paginated list of the current user's conversations. Returns `{ data, total, limit, offset }`."
          }
        },
        {
          "name": "Get conversation with messages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/conversations/{{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "conversations", "{{conversationId}}"]
            },
            "description": "Returns the conversation plus its `messages[]`. 403 if it belongs to another user, 404 if it does not exist."
          }
        },
        {
          "name": "Delete conversation",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/conversations/{{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "conversations", "{{conversationId}}"]
            },
            "description": "Deletes the conversation and cascades to its messages. Returns 204 No Content."
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send message (SSE stream)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/event-stream" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversationId\": \"{{conversationId}}\",\n  \"message\": \"What was Apple's total revenue in the latest fiscal year?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat"]
            },
            "description": "Streams the AI answer as Server-Sent Events (`text/event-stream`).\n\nEvent types: `started`, `tool_start`, `tool_query`, `tool_end`, `token`, `done`, `tool_error`, `error`.\n\nNote: Postman renders the raw SSE stream. Returns 429 with `{ message, resetIn }` when over the usage budget. `message` must be 1–4000 chars."
          }
        },
        {
          "name": "Stop stream",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversationId\": \"{{conversationId}}\",\n  \"messageId\": \"{{messageId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/stop",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "stop"]
            },
            "description": "Aborts an in-flight chat stream. Returns `{ messageId, stopped, content }`. `messageId` comes from the `started` SSE event of the active stream."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Liveness + dependency check. Returns `{ status, timestamp, services: { postgres, redis } }`. Not under the `/api` prefix."
          }
        }
      ]
    }
  ]
}
