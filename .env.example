# ─────────────────────────────────────────────────────────────
# Financial AI Chat Assistant — Environment Configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL 16) ──────────────────────────────────
# For local (non-Docker) dev use localhost. Docker Compose overrides
# the host to the `postgres` service automatically.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finchat
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finchat

# ── Redis 7 ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (JWT) ────────────────────────────────────────────────
# JWT_SECRET must be at least 32 characters.
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRY=24h

# ── AI Provider (OpenAI or Anthropic) ─────────────────────────
# The project supports BOTH vendors behind one interface. AI_PROVIDER
# selects the active one; the inactive vendor's key may be left blank.
AI_PROVIDER=openai                 # "openai" | "anthropic"
AI_MAX_HISTORY_MESSAGES=20         # conversation turns sent to the model
CHAT_STOP_GRACE_PERIOD_MS=2000     # pause before calling the model, so the user can Stop (0 disables)
# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# ── Usage Limit ───────────────────────────────────────────────
USAGE_BUDGET_USD=1.0
USAGE_RESET_INTERVAL_SECONDS=3600

# ── CORS / Frontend ───────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Backend ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Frontend (Vite) ───────────────────────────────────────────
# Consumed at build/dev time by the Vite app.
VITE_API_URL=http://localhost:3000
